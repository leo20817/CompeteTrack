# CompeteTrack Environment Variables
# Copy to .env and fill in actual values
# NEVER commit .env to git

# ── Database ──
DATABASE_URL=postgresql+asyncpg://user:password@db.supabase.co:5432/postgres

# ── Supabase (reserved for future auth) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...  # public anon key (safe to expose in future frontend)

# ── External APIs (server-side only, NEVER prefix with NEXT_PUBLIC_) ──
GOOGLE_PLACES_API_KEY=AIza...
CLAUDE_API_KEY=sk-ant-...
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=notifications@yourdomain.com
FRONTEND_URL=https://competetrack.zeabur.app  # used in email CTA links

# ── App Config ──
APP_ENV=development  # development | production
APP_PORT=8000
LOG_LEVEL=info
OWNER_USER_EMAIL=your@email.com  # MVP: the single user's email

# ── Frontend (Next.js) ──
# This is the ONLY NEXT_PUBLIC_ variable
NEXT_PUBLIC_API_URL=http://localhost:8000  # dev | https://api.competetrack.zeabur.app (prod)

# ── Scheduler ──
COLLECT_HOUR=8         # Daily collection time (24h, Vietnam timezone)
COLLECT_MINUTE=0
DIGEST_EMAIL_HOUR=8
DIGEST_EMAIL_MINUTE=30
TIMEZONE=Asia/Ho_Chi_Minh
